            "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/10.0.302/dotnet-sdk-10.0.302-win-x64.zip",
            "hash": "sha512:7d170ed75fa9af34c00646621d92011dbd71943952e2787cd15df9be78e6452b55dadef34d7eff77b802e6af4959e071a55855ac649afeac70901c3a2a258716"
        },
        "32bit": {
            "url": "https://dotnetcli.blob.core.windows.net/dotnet/Sdk/10.0.302/dotnet-sdk-10.0.302-win-x86.zip",
            "hash": "sha512:39400959121917bb3cc7811287a9dff6b6ab9cb5142b274fbd8ee89d95a1b6f01869bb273785ecc44d416afda7f9e92485b3b20049b600749f87902e0898ba8c"
